# Node.js 依赖目录
node_modules/

# Vite 构建输出目录
dist/

# 本地环境变量文件
.env.local
.env.*.local

# 日志文件
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# WebStorm/IntelliJ 配置目录
.idea/

# VSCode 配置目录（如果你用 VSCode）
.vscode/

# 缓存和临时目录
.cache/
temp/
tmp/
*.tmp

# 操作系统文件
.DS_Store
Thumbs.db

# 锁文件（如果团队用不同的包管理器，也可以保留）
# package-lock.json
 yarn.lock
# pnpm-lock.yaml

# 本地历史插件
.history/
/.yarn/install-state.gz
/.yarnrc.yml
/package.tmp.json
/dev.log
/.pnp.cjs
/.pnp.loader.mjs
/vite.config.ts.timestamp-1757754407442-de771391983ae.mjs
/mgkw*